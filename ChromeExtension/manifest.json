{
  "manifest_version": 3,
  "name": "Audiolens",
  "version": "1.2.0",
  "permissions": ["storage", "offscreen", "identity"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "tesseract/*",
        "offscreen.html",
        "offscreen.js",
        "offscreen-init.js",
        "offscreen-setup.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}